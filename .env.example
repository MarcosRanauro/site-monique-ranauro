# Resend — API de envio de e-mail
# Obrigatório para o formulário de contato funcionar
RESEND_API_KEY=your_resend_api_key_here

# E-mail de origem do formulário de contato
# Deve usar domínio verificado no Resend
# Padrão: Site Monique Ranauro <site@moniqueranauro.com.br>
CONTACT_EMAIL_FROM=

# E-mail de destino das mensagens do formulário
# Padrão: moniqueranauro@gmail.com
CONTACT_EMAIL_TO=

# Supabase — armazenamento de contatos recebidos
# Opcional: se não configurado, contatos não são salvos no banco
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Upstash Redis — rate limiting do formulário de contato
# Opcional: se não configurado, rate limiting é desativado
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Painel administrativo — /acesso
# Obrigatório para autenticar no painel de contatos
ADMIN_PASSWORD=your_admin_password_here

# Supabase Service Role Key — usada apenas no servidor para leitura dos contatos no painel admin
# Nunca expor no client (sem NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
