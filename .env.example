# Resend — API de envio de e-mail
# Obrigatório para o formulário de contato funcionar
RESEND_API_KEY=your_resend_api_key_here

# E-mail de origem do formulário de contato
# Deve usar domínio verificado no Resend
# Padrão: Site Monique Ranauro <site@moniqueranauro.com.br>
CONTACT_EMAIL_FROM=

# E-mail de destino das mensagens do formulário
# Padrão: moniqueranauro@gmail.com
CONTACT_EMAIL_TO=
